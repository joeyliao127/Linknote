REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# MQ
MQ_HOST=172.100.10.104

# FE
FRONTEND_HOST=172.100.10.105
FRONTEND_PORT=3000


# BFF Path (for client)
API_URL="/api"

# Backend Service Paths

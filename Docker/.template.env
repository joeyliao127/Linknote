COMPOSE_PROJECT_NAME=linknote
PROJECT_NAME=linknote

# Docker network
DOCKER_NETWORK=172.100.0.0/16

#Nginx
NGINX_HOST=172.100.10.101

# PG
POSTGRES_HOST=172.100.10.102
# 自動建立 linknote DB
POSTGRES_DB=linknote
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_PORT=5432
# Note: PG shm size 是一個shared memory，應該算一種buffer
# 大小設定取決於實際用量，可以到 dokcer logs 裡面找到
POSTGRES_SHM_SIZE=512

#Redis
REDIS_HOST=172.100.10.103
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# MQ
MQ_HOST=172.100.10.104

# FE
FRONTEND_HOST=172.100.10.105
FRONTEND_PORT=3000


# BFF Path (for client)
API_URL="/api"

# Backend Service Paths
AUTH_API_BASE="http://springboot:8080/api"
RESOURCE_API_BASE="http://springboot:8080/api"

# Nuxt runtimeConfig overrides (需要 NUXT_ 前綴)
NUXT_AUTH_API=http://springboot:8080/api
NUXT_RESOURCE_API=http://springboot:8080/api
NUXT_RAG_API=http://fastapi:8001

#BE
# 產生JWT_SECRET: openssl rand -hex 32
JWT_SECRET=
BACKEND_HOST=172.100.10.106
BACKEND_PORT=8080
DEBUG_PORT=5005
AUTH_API_BASE=http://springboot:8080/api
AUTH_SECRET=dev-auth-secret-change-me

# For local development services

# PGADMIN
PGADMIN_HOST=172.100.10.107
PGADMIN_EMAIL=dev@dev.com
PGADMIN_PASSWORD=dev
PGADMIN_PORT=8889

#Qdrant
QDRANT_HOST=172.100.10.108
QDRANT_PORT=6333
# 產生 API Key: openssl rand -hex 32
QDRANT_API_KEY=

# RAG Service (FastAPI)
RAG_HOST=172.100.10.109
RAG_PORT=8001
RAG_API_BASE=http://fastapi:8001
# COSINE(BGE/text-embedding 系列) | DOT(已 normalize 向量) | EUCLID(絕對距離)
QDRANT_DISTANCE=COSINE
# Embedding provider: "ollama" (local, bge-m3, 1024-dim) | "openai" (text-embedding-3-small, 1536-dim)
EMBEDDING_PROVIDER=ollama
OPENAPI_EMBEDDING=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Ollama 跑在 host 機器上，Docker 內用 host.docker.internal 存取
OLLAMA_BASE_URL=http://host.docker.internal:11434